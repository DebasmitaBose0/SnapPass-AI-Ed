# Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (never commit .env to Git).
#   cp .env.example .env
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
#
#   Development  → leave empty; the Vite proxy handles forwarding to :3000
#                   (configured in vite.config.js → server.proxy)
#   Production   → point at your deployed backend (e.g. Render, Railway, EC2)
#
# VITE_API_URL=http://localhost:3000/api