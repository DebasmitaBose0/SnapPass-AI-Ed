{
  "name": "snappass-ai-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "SnapPass AI — Monorepo root for passport photo generation platform",
  "scripts": {
    "lint": "eslint . --ext .js,.jsx,.json --ignore-pattern node_modules --ignore-pattern dist --ignore-pattern build --ignore-pattern '*.json'",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\"",
    "quality-gate": "npm run lint && npm run test",
    "security-audit": "npm audit"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
